# ──────────────────────────────────────────────────────────
# FindRE — environment variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# RapidAPI key for zillo-realtime-scraper.p.rapidapi.com
# Get yours at: https://rapidapi.com/apimaker/api/zillo-realtime-scraper
# Required for live Zillow data; app falls back to demo data if unset.
ZILLOW_API_KEY=

# Backend port (default: 8000)
PORT=8000

# Ollama base URL
# Docker Compose: http://host.docker.internal:11434
# Local dev:      http://localhost:11434
OLLAMA_HOST=http://localhost:11434
